# =============================================================================
# GLOBAL SETTINGS
# =============================================================================

# Preferred LLM Provider
# Options: openai, anthropic, google, mistral, cohere, groq, ollama, etc.
VITE_PREFERRED_LLM=openai

# Debug logging setting
# Set to true to enable console logging, false to disable
VITE_DEBUG_LOG=true

# =============================================================================
# OPENAI SETTINGS
# =============================================================================

# OpenAI API Key
# Get your key at: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Preferred Model
# Options: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo, etc.
VITE_OPENAI_PREFERRED_MODEL=gpt-4o

# =============================================================================
# PERPLEXITY SETTINGS
# =============================================================================

# Perplexity API Key
# Get your key at: https://www.perplexity.ai/settings/api
VITE_PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Perplexity Preferred Model
# Options: sonar, sonar-pro, sonar-reasoning, sonar-reasoning-pro, sonar-deep-research
VITE_PERPLEXITY_PREFERRED_MODEL=sonar
